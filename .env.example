# ─────────────────────────────────────────────────────────────────────────────
# Efficiency Media (Vite site) — Sanity read config.
# Copy this file to `.env.local` and fill in your values.
#   cp .env.example .env.local        (PowerShell: Copy-Item .env.example .env.local)
# Vite only exposes vars prefixed with VITE_ to the browser. These are PUBLIC
# (read-only API) — safe to ship.
# ─────────────────────────────────────────────────────────────────────────────

# Required. From `npm create sanity@latest` output or manage.sanity.io.
VITE_SANITY_PROJECT_ID="your_project_id"

# Required. Defaults to "production".
VITE_SANITY_DATASET="production"

# Optional. Pin the Sanity API version (date-based).
VITE_SANITY_API_VERSION="2024-06-01"
